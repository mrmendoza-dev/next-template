		"check": "biome ci .",
		"ci": "turbo run lint test build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "mkdir -p data && bun run scripts/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
