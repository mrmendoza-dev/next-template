{
	"name": "next-template",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.4",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
