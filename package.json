		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-react": "^8.6.0",
		"framer-motion": "^12.38.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.8.0",
		"next": "16.2.4",
		"next-themes": "^0.4.6",
		"react": "19.2.5",
		"react-day-picker": "^9.14.0",
		"react-dom": "19.2.5",
		"react-resizable-panels": "^4.10.0",
